      "op": "<=",
      "value": 1344,
      "unit": "ms",
      "reason": "Warm Test voice previews must remain responsive."
    },
    {
      "id": "warm-preview-p95-max",
      "metric": "warmPreviewLatency.p95",
      "op": "<=",
      "value": 1388,
      "unit": "ms",
      "reason": "Tail warm Test voice preview latency must stay within the approved narration-lane budget."
    },
    {
      "id": "warm-first-audio-p50-max",
      "metric": "warmFirstAudioLatency.p50",
      "op": "<=",
      "value": 558,
      "unit": "ms",
      "reason": "Median warm first-audio latency must stay within the approved narration-lane budget."
    },
    {
      "id": "warm-first-audio-p95-max",
      "metric": "warmFirstAudioLatency.p95",
      "op": "<=",
      "value": 610,
      "unit": "ms",
      "reason": "Tail warm first-audio latency must stay within the approved narration-lane budget."
    },
    {
      "id": "drift-p95-max",
      "metric": "drift.p95",
      "op": "<=",
      "value": 3,
      "unit": "words",
      "reason": "Cursor/highlight drift must remain tightly aligned."
    },
    {
      "id": "pause-resume-failures-max",
      "metric": "failureCounts.pauseResumeFailures",
      "op": "<=",
      "value": 0,
      "unit": "count",
      "reason": "Pause/resume integrity failures block release."
    },
    {
      "id": "handoff-failures-max",
      "metric": "failureCounts.handoffFailures",
      "op": "<=",
      "value": 0,
      "unit": "count",
      "reason": "Cross-book handoff failures block release."
    }
  ],
  "warnOnly": [
    {
      "id": "warm-preview-max-warning",
      "metric": "warmPreviewLatency.max",
      "op": "<=",
      "value": 1416,
      "unit": "ms",
      "reason": "Warm preview spikes above baseline headroom require reviewer acknowledgement."
    },
    {
      "id": "warm-first-audio-max-warning",
      "metric": "warmFirstAudioLatency.max",
      "op": "<=",
      "value": 610,
      "unit": "ms",
      "reason": "Warm first-audio spikes above baseline headroom require reviewer acknowledgement."
    },
    {
      "id": "drift-max-warning",
      "metric": "drift.max",
      "op": "<=",
      "value": 3,
      "unit": "words",
      "reason": "Any max drift above baseline headroom should be reviewed before release."
    }
  ]
